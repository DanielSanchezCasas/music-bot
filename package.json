{
  "name": "bot-discord",
  "version": "1.0.0",
  "main": "src/index.js",
  "packageManager": "pnpm@10.11.0",
  "engines": {
    "node": ">=20.18.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "ffmpeg-static",
      "youtube-dl-exec"
    ],
    "overrides": {
      "esbuild": "^0.28.1",
      "shell-quote": "^1.8.4",
      "form-data": "^4.0.6",
      "ws": "^8.21.0",
      "file-type": "^21.3.1",
      "js-yaml": "^4.2.0"
    }
  },
  "scripts": {
    "start": "node src/index.js",
    "start:dev": "concurrently -n bot,web -c blue,green \"node src/index.js\" \"wait-on -t 120000 http-get://127.0.0.1:3000/api/health && pnpm --dir web dev\"",
    "build:web": "pnpm --dir web build",
    "docker:up": "docker compose up -d --build",
    "docker:logs": "docker compose logs -f --tail 50 music-bot",
    "dev:web": "pnpm --dir web dev",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "type": "module",
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@discord-player/extractor": "^7.1.0",
    "@fastify/static": "^9.1.1",
    "@fastify/websocket": "^11.0.2",
    "@snazzah/davey": "^0.1.11",
    "discord-player": "^7.1.0",
    "discord-player-youtubei": "3.0.0-beta.4",
    "discord.js": "^14.18.0",
    "dotenv": "^16.5.0",
    "fastify": "^5.2.1",
    "ffmpeg-static": "^5.2.0",
    "mediaplex": "^1.0.0",
    "youtube-dl-exec": "^3.1.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "concurrently": "^9.1.2",
    "eslint": "^9.25.0",
    "wait-on": "^8.0.3"
  }
}

# === Obligatorio ===
TOKEN_BOT=
# Uno o varios servidores (separados por coma). La web usa el que tenga gente en voz.
# GUILD_ID=1234567890123456789,9876543210987654321
GUILD_ID=

# === Interfaz web CasaOS (puerto 3000) ===
WEB_PORT=3000
WEB_API_TOKEN=

# === Opcional ===
PREFIX_BOT=!
# TEXT_CHANNEL_ID=
# VOICE_CHANNEL_ID=

# === CasaOS / Docker (ya vienen en docker-compose.yml) ===
# WEB_DISABLE_TERMINAL_PANEL=true

# Si YouTube falla con "Could not extract stream", exporta cookies del navegador:
# YOUTUBE_COOKIE=CONSENT=YES+1; VISITOR_INFO1_LIVE=...
